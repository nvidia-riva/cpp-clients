package(
    default_visibility = ["//visibility:public"],
)

cc_library(
    name = "websocketpp",
    hdrs = glob([
        "websocketpp/*.hpp",
        "websocketpp/**/*.hpp"
    ]),
    strip_include_prefix = ".",
    deps = [
        "@com_google_absl//absl/strings",
    ],
) 